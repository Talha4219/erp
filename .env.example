# ──────────────────────────────────────────────
# ERPNext Integration (optional — remove if unused)
# ──────────────────────────────────────────────
ERPNEXT_URL="http://localhost:8080"
ERPNEXT_API_KEY=""
ERPNEXT_API_SECRET=""

# ──────────────────────────────────────────────
# Database — PostgreSQL via Prisma
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/db_name?sslmode=require"

# ──────────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ──────────────────────────────────────────────
# SMTP / Email
# ──────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL="noreply@example.com"
SMTP_FROM_NAME="ERP"

# ──────────────────────────────────────────────
# Biometric Device Webhook
# ──────────────────────────────────────────────
# Shared secret that biometric punch devices send in the Authorization header
# Generate with: openssl rand -base64 32
BIOMETRIC_WEBHOOK_SECRET=""

# ──────────────────────────────────────────────
# Stripe — Payments
# ──────────────────────────────────────────────
# Secret key (server-side only — NEVER expose to the browser)
# Find yours at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret (server-side only)
STRIPE_WEBHOOK_SECRET="whsec_..."
# Publishable key (safe to expose to the browser via NEXT_PUBLIC_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ──────────────────────────────────────────────
# Public (NEXT_PUBLIC_*) — safe to expose to the browser
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="ERP"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
