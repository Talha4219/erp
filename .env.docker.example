# Copy to .env for docker-compose:  cp .env.docker.example .env
# docker-compose reads .env automatically for both variable substitution
# and the container runtime environment.

# ─── Postgres (the `db` service) ──────────────────────────────────────────────
POSTGRES_USER=erp
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=erp_db
POSTGRES_PORT=5432

# ─── App database connection ──────────────────────────────────────────────────
# Host is the compose service name `db`, NOT localhost.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above.
DATABASE_URL=postgresql://erp:change_me_strong_password@db:5432/erp_db

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_a_32_char_secret

# ─── App (build-time public vars + host port) ─────────────────────────────────
NEXT_PUBLIC_APP_NAME=ERP
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_PORT=3000

# ─── Email (SMTP) — optional ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ERP


