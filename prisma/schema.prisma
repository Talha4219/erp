// ─── AUTH & USERS ─────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  name             String?
  password         String
  role             Role       @default(VIEWER)
  status           UserStatus @default(ACTIVE)
  isActive         Boolean    @default(true)
  phone            String?
  avatarUrl        String?
  address          String?
  bio              String?
  onboardingDone   Boolean    @default(false)
  branchId         String?
  departmentId     String?
  loginAttempts    Int        @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?
  defaultCompanyId String?

  defaultCompany    Company?             @relation("UserDefaultCompany", fields: [defaultCompanyId], references: [id])
  branch            Branch?              @relation("UserBranch", fields: [branchId], references: [id])
  userDept          Department?          @relation("UserDept", fields: [departmentId], references: [id])
  employee          Employee?
  auditLogs         AuditLog[]
  approvedLeaves    Leave[]              @relation("LeaveApprover")
  assignedTasks     ProjectTask[]        @relation("TaskAssignee")
  journalEntries    JournalEntry[]
  notifications     Notification[]
  dashboardConfig   DashboardConfig?
  workflowInstances WorkflowInstance[]   @relation("WorkflowRequester")
  workflowActions   WorkflowAction[]
  userRoles         UserRole[]
  userGroups        UserGroupMember[]
  sessions          UserSession[]
  delegationsFrom   ApprovalDelegation[] @relation("DelegationFrom")
  delegationsTo     ApprovalDelegation[] @relation("DelegationTo")

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([branchId])
  @@index([deletedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── HR MODULE ────────────────────────────────────────────────────────────────

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  description String?
  managerId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  employees      Employee[]
  manager        Employee?       @relation("DeptManager", fields: [managerId], references: [id])
  jobPostings    JobPosting[]
  users          User[]          @relation("UserDept")
  vendorInvoices VendorInvoice[]

  @@index([deletedAt])
  @@index([managerId])
}

model Designation {
  id        String    @id @default(cuid())
  name      String    @unique
  code      String    @unique
  level     Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees Employee[]

  @@index([deletedAt])
}

model EmployeeType {
  id        Int      @id @default(autoincrement())
  typeName  String   @unique
  isBuiltIn Boolean  @default(false)
  createdAt DateTime @default(now())

  employees Employee[]
}

model Employee {
  id              String       @id @default(cuid())
  employeeCode    String       @unique
  userId          String?      @unique
  firstName       String
  lastName        String
  email           String       @unique
  phone           String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  nationalId      String?
  departmentId    String
  designationId   String
  contractType    ContractType @default(FULL_TIME)
  employeeTypeId  Int?
  joinDate        DateTime
  terminationDate DateTime?
  basicSalary     Decimal      @db.Decimal(15, 2)
  bankAccount     String?
  bankName        String?
  profileImage    String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  // UK Retail HR extensions
  niNumber             String?   @unique @db.VarChar(9)
  payrollId            String?   @unique
  hourlyRateGbp        Decimal?  @db.Decimal(5, 2)
  rightToWorkProofSeen Boolean   @default(false)
  rightToWorkDocType   String?
  visaExpiryDate       DateTime?
  pensionEnrolled      Boolean   @default(false)

  user               User?                  @relation(fields: [userId], references: [id])
  department         Department             @relation(fields: [departmentId], references: [id])
  designation        Designation            @relation(fields: [designationId], references: [id])
  employeeType       EmployeeType?          @relation(fields: [employeeTypeId], references: [id])
  managedDepts       Department[]           @relation("DeptManager")
  attendances        Attendance[]
  leaves             Leave[]
  payrolls           Payroll[]
  shifts             ShiftRoster[]
  documents          EmployeeDocument[]
  onboardings        EmployeeOnboarding[]
  biometricLogs      BiometricLog[]
  leaveBalances      LeaveBalance[]
  appraisals         PerformanceAppraisal[]
  reviewedAppraisals PerformanceAppraisal[] @relation("AppraisalReviewer")
  kpis               EmployeeKpi[]
  reviews            PerformanceReview[]
  conductedReviews   PerformanceReview[]    @relation("ReviewerEmployee")

  @@index([departmentId])
  @@index([designationId])
  @@index([isActive])
  @@index([employeeTypeId])
  @@index([deletedAt])
}

// Generic binary upload storage (e.g. employee photos), served back via /api/uploads/[id].
// Replaces writing files to the public/ folder, which put binaries under git and served
// them with no auth check.
model UploadedFile {
  id        String   @id @default(cuid())
  fileName  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())
}

model Attendance {
  id          String    @id @default(cuid())
  employeeId  String
  date        DateTime  @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      String    @default("PRESENT") // PRESENT, ABSENT, HALF_DAY, LEAVE
  hoursWorked Decimal?  @db.Decimal(5, 2)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([deletedAt])
}

model Leave {
  id            String      @id @default(cuid())
  employeeId    String
  leaveType     LeaveType
  startDate     DateTime    @db.Date
  endDate       DateTime    @db.Date
  totalDays     Int
  reason        String?
  status        LeaveStatus @default(PENDING)
  approverId    String?
  approvedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
  approver User?    @relation("LeaveApprover", fields: [approverId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([deletedAt])
  @@index([createdAt])
}

model Payroll {
  id              String    @id @default(cuid())
  employeeId      String
  month           Int
  year            Int
  basicSalary     Decimal   @db.Decimal(15, 2)
  allowances      Decimal   @default(0) @db.Decimal(15, 2)
  overtime        Decimal   @default(0) @db.Decimal(15, 2)
  grossSalary     Decimal   @db.Decimal(15, 2)
  taxDeduction    Decimal   @default(0) @db.Decimal(15, 2)
  socialSecurity  Decimal   @default(0) @db.Decimal(15, 2)
  otherDeductions Decimal   @default(0) @db.Decimal(15, 2)
  totalDeductions Decimal   @db.Decimal(15, 2)
  netSalary       Decimal   @db.Decimal(15, 2)
  payeDeduction   Decimal   @default(0) @db.Decimal(15, 2)
  niEmployee      Decimal   @default(0) @db.Decimal(15, 2)
  niEmployer      Decimal   @default(0) @db.Decimal(15, 2)
  pensionEmployee Decimal   @default(0) @db.Decimal(15, 2)
  pensionEmployer Decimal   @default(0) @db.Decimal(15, 2)
  isPaid          Boolean   @default(false)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  employee Employee      @relation(fields: [employeeId], references: [id])
  items    PayrollItem[]

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([month, year])
  @@index([deletedAt])
  @@index([isPaid])
}

// ─── PROCUREMENT MODULE ───────────────────────────────────────────────────────

model Vendor {
  id            String    @id @default(cuid())
  vendorCode    String    @unique
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?
  taxId         String?
  paymentTerms  Int       @default(30) // days
  creditLimit      Decimal?  @db.Decimal(15, 2)
  rating           Int       @default(3)
  bankAccountNumber String?
  bankSortCode     String?
  leadTimeDays     Int       @default(7)
  isActive         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]
  vendorInvoices       VendorInvoice[]
  contacts             SupplierContact[]
  ratings              SupplierRating[]
  rfqs                 Rfq[]
  supplierQuotations   SupplierQuotation[]
  purchaseReturns      PurchaseReturn[]
  expenses             Expense[]
  inventoryBatches     InventoryBatch[]

  @@index([isActive])
  @@index([deletedAt])
}

model PurchaseRequisition {
  id            String            @id @default(cuid())
  prNumber      String            @unique
  requestedById String
  vendorId      String?
  sourceSoId    String?
  department    String?
  requiredDate  DateTime          @db.Date
  status        RequisitionStatus @default(DRAFT)
  priority      String            @default("MEDIUM")
  totalAmount   Decimal           @default(0) @db.Decimal(15, 2)
  notes         String?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  vendor        Vendor?        @relation(fields: [vendorId], references: [id])
  sourceSo      SalesOrder?    @relation(fields: [sourceSoId], references: [id])
  lineItems     PRLineItem[]
  purchaseOrder PurchaseOrder?
  rfqs          Rfq[]

  @@index([status])
  @@index([sourceSoId])
  @@index([deletedAt])
  @@index([requestedById])
  @@index([vendorId])
}

model PRLineItem {
  id                 String  @id @default(cuid())
  prId               String
  itemId             String?
  description        String
  quantity           Decimal @db.Decimal(15, 3)
  uom                String
  estimatedUnitPrice Decimal @db.Decimal(15, 2)
  totalPrice         Decimal @db.Decimal(15, 2)

  pr   PurchaseRequisition @relation(fields: [prId], references: [id], onDelete: Cascade)
  item Item?               @relation(fields: [itemId], references: [id])

  @@index([prId])
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  prId         String?   @unique
  sqId         String?   @unique
  vendorId     String
  companyId    String?
  orderDate    DateTime  @db.Date
  deliveryDate DateTime? @db.Date
  status       POStatus  @default(DRAFT)
  totalAmount  Decimal   @db.Decimal(15, 2)
  taxAmount    Decimal   @default(0) @db.Decimal(15, 2)
  shippingCost Decimal   @default(0) @db.Decimal(15, 2)
  grandTotal   Decimal   @db.Decimal(15, 2)
  terms        String?
  notes        String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  vendor         Vendor               @relation(fields: [vendorId], references: [id])
  company        Company?             @relation("CompanyPurchaseOrders", fields: [companyId], references: [id])
  pr             PurchaseRequisition? @relation(fields: [prId], references: [id])
  quotation      SupplierQuotation?   @relation(fields: [sqId], references: [id])
  lineItems      POLineItem[]
  grns           GoodsReceiptNote[]
  vendorInvoices VendorInvoice[]

  @@index([vendorId])
  @@index([companyId])
  @@index([status])
  @@index([deletedAt])
  @@index([approvedById])
  @@index([orderDate])
}

model POLineItem {
  id          String  @id @default(cuid())
  poId        String
  itemId      String?
  description String
  quantity    Decimal @db.Decimal(15, 3)
  receivedQty Decimal @default(0) @db.Decimal(15, 3)
  uom         String
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  totalPrice  Decimal @db.Decimal(15, 2)

  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  item         Item?         @relation(fields: [itemId], references: [id])
  grnLineItems GRNLineItem[]

  @@index([poId])
}

model GoodsReceiptNote {
  id           String   @id @default(cuid())
  grnNumber    String   @unique
  poId         String
  companyId    String?
  receivedDate DateTime @db.Date
  receivedById String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  po              PurchaseOrder    @relation(fields: [poId], references: [id])
  company         Company?         @relation("CompanyGRNs", fields: [companyId], references: [id])
  lineItems       GRNLineItem[]
  purchaseReturns PurchaseReturn[]

  @@index([poId])
  @@index([companyId])
}

model GRNLineItem {
  id           String  @id @default(cuid())
  grnId        String
  poLineItemId String?
  itemId       String?
  receivedQty  Decimal @db.Decimal(15, 3)
  acceptedQty  Decimal @db.Decimal(15, 3)
  rejectedQty  Decimal @default(0) @db.Decimal(15, 3)
  unitPrice    Decimal @db.Decimal(15, 2)
  warehouseId  String?
  locationCode String?

  grn        GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poLineItem POLineItem?      @relation(fields: [poLineItemId], references: [id])
  item       Item?            @relation(fields: [itemId], references: [id])

  @@index([grnId])
}

model VendorInvoice {
  id               String         @id @default(cuid())
  invoiceNumber    String         @unique
  vendorId         String
  poId             String?
  invoiceDate      DateTime       @db.Date
  dueDate          DateTime       @db.Date
  subTotal         Decimal        @db.Decimal(15, 2)
  taxAmount        Decimal        @default(0) @db.Decimal(15, 2)
  shippingCharges  Decimal        @default(0) @db.Decimal(15, 2)
  discountAmount   Decimal        @default(0) @db.Decimal(15, 2)
  totalAmount      Decimal        @db.Decimal(15, 2)
  paidAmount       Decimal        @default(0) @db.Decimal(15, 2)
  status           InvoiceStatus  @default(DRAFT)
  matchingStatus   MatchingStatus @default(PENDING)
  currencyCode     String         @default("GBP")
  exchangeRate     Decimal?       @default(1) @db.Decimal(15, 6)
  departmentId     String?
  costCentreId     String?
  approvalComments String?
  financeNotes     String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  vendor          Vendor              @relation(fields: [vendorId], references: [id])
  po              PurchaseOrder?      @relation(fields: [poId], references: [id])
  department      Department?         @relation(fields: [departmentId], references: [id])
  costCentre      CostCentre?         @relation(fields: [costCentreId], references: [id])
  items           VendorInvoiceItem[]
  payments        VendorPayment[]
  purchaseReturns PurchaseReturn[]

  @@index([vendorId])
  @@index([status])
  @@index([deletedAt])
  @@index([departmentId])
  @@index([matchingStatus])
  @@index([poId])
}

model VendorInvoiceItem {
  id           String  @id @default(cuid())
  invoiceId    String
  itemId       String?
  description  String
  quantity     Decimal @default(1) @db.Decimal(15, 3)
  unitPrice    Decimal @db.Decimal(15, 2)
  taxRate      Decimal @default(0) @db.Decimal(5, 2)
  discount     Decimal @default(0) @db.Decimal(15, 2)
  totalPrice   Decimal @db.Decimal(15, 2)
  glAccountId  String?
  warehouseId  String?
  costCentreId String?
  projectId    String?

  invoice    VendorInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item       Item?         @relation(fields: [itemId], references: [id])
  glAccount  Account?      @relation(fields: [glAccountId], references: [id])
  warehouse  Warehouse?    @relation(fields: [warehouseId], references: [id])
  costCentre CostCentre?   @relation(fields: [costCentreId], references: [id])
  project    Project?      @relation(fields: [projectId], references: [id])

  @@index([invoiceId])
}

model VendorPayment {
  id              String   @id @default(cuid())
  vendorInvoiceId String
  amount          Decimal  @db.Decimal(15, 2)
  paymentDate     DateTime @db.Date
  paymentMethod   String
  reference       String?
  notes           String?
  createdAt       DateTime @default(now())

  vendorInvoice VendorInvoice @relation(fields: [vendorInvoiceId], references: [id])

  @@index([vendorInvoiceId])
}

// ─── INVENTORY MODULE ─────────────────────────────────────────────────────────

model ItemCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   ItemCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryHierarchy")
  items    Item[]
}

model Item {
  id            String    @id @default(cuid())
  sku           String    @unique
  barcode          String?   @unique // one barcode = one product; scanned at POS/GRN/stock count
  barcodeType      String    @default("CODE128") // CODE128 | EAN13 | EAN8 | UPCA | UPCE | CODE39 | QR
  secondaryBarcode String? // optional supplier/case barcode alongside the primary
  name          String
  description   String?
  categoryId    String
  uom           String // Unit of Measure
  packing       String? // Packing/weight variant, e.g. "2kg", "500g", "12x1L"
  reorderPoint  Decimal   @default(0) @db.Decimal(15, 3)
  reorderQty    Decimal   @default(0) @db.Decimal(15, 3)
  standardCost  Decimal   @default(0) @db.Decimal(15, 2)
  sellingPrice  Decimal   @default(0) @db.Decimal(15, 2)
  vatRate       Decimal   @default(0.20) @db.Decimal(4, 2) // VAT rate applied when sold via POS
  locationAisle String?   // retail shelf/aisle location
  expiryDate    DateTime?
  isActive      Boolean   @default(true)
  isSellable    Boolean   @default(true)
  isPurchasable Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  category            ItemCategory         @relation(fields: [categoryId], references: [id])
  stockLedgers        StockLedger[]
  warehouseStocks     WarehouseStock[]
  prLineItems         PRLineItem[]
  poLineItems         POLineItem[]
  grnLineItems        GRNLineItem[]
  salesOrderItems     SalesOrderItem[]
  invoiceItems        InvoiceItem[]
  priceListItems      PriceListItem[]
  stockTransferItems  StockTransferItem[]
  cycleCountItems     CycleCountItem[]
  serialNumbers       SerialNumber[]
  stockReservations   StockReservation[]
  batches             InventoryBatch[]
  variants            ItemVariant[]
  unifiedSalesOrderItems SalesOrderItemV2[]
  vendorInvoiceItems     VendorInvoiceItem[]
  salesReturnItems    SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]

  fulfillmentOrderItems    FulfillmentOrderItem[]
  packageItems             PackageItem[]
  pickListItems            PickListItem[]
  internalTransferItems    InternalTransferItem[]
  returnRequestItems       ReturnRequestItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([barcode])
  @@index([secondaryBarcode])
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks              WarehouseStock[]
  ledgers             StockLedger[]
  transfersFrom       StockTransfer[]      @relation("TransferFrom")
  transfersTo         StockTransfer[]      @relation("TransferTo")
  cycleCounts         CycleCount[]
  serialNumbers       SerialNumber[]
  stockReservations   StockReservation[]
  vendorInvoiceItems  VendorInvoiceItem[]
  salesReturnItems    SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]

  fulfillmentOrders       FulfillmentOrder[]
  pickLists               PickList[]
  internalTransfersFrom   InternalTransfer[] @relation("InternalTransferFrom")
  internalTransfersTo     InternalTransfer[] @relation("InternalTransferTo")
  returnRequests          ReturnRequest[]
}

model WarehouseStock {
  id          String   @id @default(cuid())
  warehouseId String
  itemId      String
  quantity    Decimal  @default(0) @db.Decimal(15, 3)
  avgCost     Decimal  @default(0) @db.Decimal(15, 2)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])

  @@unique([warehouseId, itemId])
  @@index([warehouseId])
  @@index([itemId])
}

model StockLedger {
  id              String          @id @default(cuid())
  itemId          String
  warehouseId     String?
  transactionType TransactionType
  quantity        Decimal         @db.Decimal(15, 3)
  unitCost        Decimal         @db.Decimal(15, 2)
  totalCost       Decimal         @db.Decimal(15, 2)
  referenceType   String? // PO, SO, ADJ, GRN
  referenceId     String?
  notes           String?
  transactionDate DateTime        @db.Date
  createdAt       DateTime        @default(now())

  item      Item       @relation(fields: [itemId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([itemId])
  @@index([warehouseId])
  @@index([transactionDate])
  @@index([referenceType, referenceId])
}

model StockTransfer {
  id              String              @id @default(cuid())
  transferNumber  String              @unique
  fromWarehouseId String
  toWarehouseId   String
  transferDate    DateTime            @db.Date
  status          StockTransferStatus @default(DRAFT)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  fromWarehouse Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  lineItems     StockTransferItem[]

  @@index([status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model StockTransferItem {
  id         String  @id @default(cuid())
  transferId String
  itemId     String
  quantity   Decimal @db.Decimal(15, 3)
  unitCost   Decimal @default(0) @db.Decimal(15, 2)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item     Item          @relation(fields: [itemId], references: [id])

  @@index([transferId])
}

model CycleCount {
  id          String           @id @default(cuid())
  countNumber String           @unique
  warehouseId String
  countDate   DateTime         @db.Date
  status      CycleCountStatus @default(DRAFT)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  lineItems CycleCountItem[]

  @@index([warehouseId])
  @@index([status])
}

model CycleCountItem {
  id           String   @id @default(cuid())
  cycleCountId String
  itemId       String
  systemQty    Decimal  @db.Decimal(15, 3)
  countedQty   Decimal? @db.Decimal(15, 3)
  variance     Decimal? @db.Decimal(15, 3)
  notes        String?

  cycleCount CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id])

  @@index([cycleCountId])
}

model SerialNumber {
  id             String             @id @default(cuid())
  serialCode     String             @unique
  itemId         String
  warehouseId    String?
  status         SerialNumberStatus @default(IN_STOCK)
  purchaseDate   DateTime?          @db.Date
  warrantyExpiry DateTime?          @db.Date
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  item      Item       @relation(fields: [itemId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([itemId])
  @@index([status])
  @@index([warehouseId])
}

// ─── SALES & CRM MODULE ───────────────────────────────────────────────────────

model Customer {
  id            String    @id @default(cuid())
  customerCode  String    @unique
  name          String
  title         String?   // Mr/Mrs/Ms (B2C)
  firstName     String?   // B2C individual given name
  lastName      String?   // B2C individual surname
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?
  taxId         String?
  creditLimit   Decimal?  @db.Decimal(15, 2)
  paymentTerms  Int       @default(30)
  dateOfBirth          DateTime?
  loyaltyPointsBalance Int       @default(0)
  marketingOptIn       Boolean   @default(false)
  gdprConsentDate      DateTime?
  dataRetentionConsent Boolean   @default(false)
  isAnonymised         Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  quotations    Quotation[]
  salesOrders      SalesOrder[]
  invoices         CustomerInvoice[]
  contacts         CrmContact[]
  opportunities    CrmOpportunity[]
  deliveryNotes    DeliveryNote[]
  returns          SalesReturn[]
  creditNotes      CreditNote[]
  ratings          CustomerRating[]
  fulfillmentOrders FulfillmentOrder[]
  returnRequests      ReturnRequest[]
  unifiedSalesOrders  SalesOrderV2[]

  @@index([isActive])
  @@index([deletedAt])
}

model Quotation {
  id              String    @id @default(cuid())
  quotationNumber String    @unique
  customerId      String
  quotationDate   DateTime  @db.Date
  expiryDate      DateTime  @db.Date
  subTotal        Decimal   @db.Decimal(15, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(15, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(15, 2)
  totalAmount     Decimal   @db.Decimal(15, 2)
  status          String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  customer   Customer        @relation(fields: [customerId], references: [id])
  lineItems  QuotationItem[]
  salesOrder SalesOrder?

  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  itemId      String?
  description String
  quantity    Decimal @db.Decimal(15, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  totalPrice  Decimal @db.Decimal(15, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model SalesOrder {
  id             String           @id @default(cuid())
  soNumber       String           @unique
  customerId     String
  companyId      String?
  quotationId    String?          @unique
  orderDate      DateTime         @db.Date
  deliveryDate   DateTime?        @db.Date
  status         SalesOrderStatus @default(DRAFT)
  subTotal       Decimal          @db.Decimal(15, 2)
  taxAmount      Decimal          @default(0) @db.Decimal(15, 2)
  discountAmount Decimal          @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal          @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  customer      Customer              @relation(fields: [customerId], references: [id])
  company       Company?              @relation("CompanySalesOrders", fields: [companyId], references: [id])
  quotation     Quotation?            @relation(fields: [quotationId], references: [id])
  lineItems      SalesOrderItem[]
  invoices       CustomerInvoice[]
  deliveryNotes  DeliveryNote[]
  reservations   StockReservation[]
  requisitions   PurchaseRequisition[]
  fulfillments   FulfillmentOrder[]
  returnRequests ReturnRequest[]

  @@index([customerId])
  @@index([companyId])
  @@index([status])
  @@index([deletedAt])
  @@index([orderDate])
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  soId         String
  itemId       String?
  description  String
  quantity     Decimal @db.Decimal(15, 3)
  deliveredQty Decimal @default(0) @db.Decimal(15, 3)
  unitPrice    Decimal @db.Decimal(15, 2)
  discount     Decimal @default(0) @db.Decimal(5, 2)
  taxRate      Decimal @default(0) @db.Decimal(5, 2)
  totalPrice   Decimal @db.Decimal(15, 2)

  so   SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  item Item?      @relation(fields: [itemId], references: [id])

  @@index([soId])
}

// ─── UNIFIED SALES ORDER (Phase 1) ────────────────────────────────────────────
// Replaces both SalesOrder (B2B) and RetailSalesOrder (POS).
// Old models remain untouched until Cleanup phase.

model SalesOrderV2 {
  id                     String                  @id @default(cuid())
  orderNumber            String                  @unique
  channel                SalesChannel
  orderType              OrderType
  workflowStatus         SalesWorkflowStatus
  paymentStatus          SalesPaymentStatus
  fulfillmentStatus      SalesFulfillmentStatus
  customerId             String?
  orderDate              DateTime                @db.Date
  deliveryDate           DateTime?               @db.Date
  subTotal               Decimal                 @db.Decimal(15, 2)
  taxAmount              Decimal                 @default(0) @db.Decimal(15, 2)
  discountAmount         Decimal                 @default(0) @db.Decimal(15, 2)
  totalAmount            Decimal                 @db.Decimal(15, 2)
  notes                  String?

  // Stripe / online payments
  stripeCustomerId        String?
  stripePaymentIntentId   String?
  stripePaymentStatus     String?
  stripeCheckoutSessionId String?
  stripeChargeId          String?

  // Compatibility: maps to old record IDs during migration
  legacyRetailId    Int?     // RetailSalesOrder.id
  legacyStandardId  String?  // SalesOrder.id

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  customer  Customer?              @relation(fields: [customerId], references: [id])
  lineItems SalesOrderItemV2[]
  payments  SalesPayment[]

  @@index([customerId])
  @@index([channel])
  @@index([workflowStatus])
  @@index([paymentStatus])
  @@index([deletedAt])
  @@index([orderDate])
}

model SalesOrderItemV2 {
  id          String  @id @default(cuid())
  soId        String
  itemId      String?
  batchId     Int?    // POS batch-specific sales
  description String
  quantity    Decimal @db.Decimal(15, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  totalPrice  Decimal @db.Decimal(15, 2)

  legacyRetailLineId Int? // populated for orders backfilled from RetailSalesLineItem

  so        SalesOrderV2    @relation(fields: [soId], references: [id], onDelete: Cascade)
  item      Item?           @relation(fields: [itemId], references: [id])
  batch     InventoryBatch? @relation(fields: [batchId], references: [id])
  payments  SalesPayment[]

  @@index([soId])
  @@index([itemId])
}

model SalesPayment {
  id                String   @id @default(cuid())
  soId              String
  soItemId          String?  // line-level tracking for refunds
  quantityReturned  Int?     // units returned (only for REFUND payments)
  amount            Decimal  @db.Decimal(15, 2)
  method                String   // CASH | CARD | TRANSFER | STRIPE | REFUND
  reference             String?
  status                String   @default("PENDING")
  stripePaymentIntentId String?
  paidAt                DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  so     SalesOrderV2    @relation(fields: [soId], references: [id])
  soItem SalesOrderItemV2? @relation(fields: [soItemId], references: [id])

  @@index([soId])
  @@index([soItemId])
}

model StockReservation {
  id          String            @id @default(cuid())
  soId        String
  soItemId    String
  itemId      String
  warehouseId String
  reservedQty Decimal           @db.Decimal(15, 3)
  status      ReservationStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())

  salesOrder SalesOrder @relation(fields: [soId], references: [id])
  item       Item       @relation(fields: [itemId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])

  @@index([soId])
  @@index([itemId])
  @@index([status])
  @@index([warehouseId])
  @@index([soItemId])
}

model CustomerInvoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  customerId     String
  companyId      String?
  soId           String?
  invoiceDate    DateTime      @db.Date
  dueDate        DateTime      @db.Date
  subTotal       Decimal       @db.Decimal(15, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(15, 2)
  discountAmount Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal       @db.Decimal(15, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(15, 2)
  status         InvoiceStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  customer  Customer          @relation(fields: [customerId], references: [id])
  company   Company?          @relation("CompanyInvoices", fields: [companyId], references: [id])
  so        SalesOrder?       @relation(fields: [soId], references: [id])
  lineItems InvoiceItem[]
  payments  CustomerPayment[]
  returns   SalesReturn[]

  @@index([customerId])
  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
  @@index([invoiceDate])
  @@index([soId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  itemId      String?
  description String
  quantity    Decimal @db.Decimal(15, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  totalPrice  Decimal @db.Decimal(15, 2)

  invoice CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item    Item?           @relation(fields: [itemId], references: [id])

  @@index([invoiceId])
}

model CustomerPayment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Decimal  @db.Decimal(15, 2)
  paymentDate DateTime @db.Date
  method      String
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())

  invoice CustomerInvoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model SupplierContact {
  id         String    @id @default(cuid())
  vendorId   String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  mobile     String?
  jobTitle   String?
  department String?
  isPrimary  Boolean   @default(false)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  vendor     Vendor    @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([deletedAt])
}

model CustomerRating {
  id                String   @id @default(cuid())
  customerId        String
  ratedByName       String
  overallScore      Int
  paymentScore      Int
  businessScore     Int
  relationshipScore Int
  notes             String?
  ratedAt           DateTime @default(now())
  customer          Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

model SupplierRating {
  id            String   @id @default(cuid())
  vendorId      String
  ratedByName   String
  overallScore  Int
  qualityScore  Int
  deliveryScore Int
  priceScore    Int
  notes         String?
  ratedAt       DateTime @default(now())
  vendor        Vendor   @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
