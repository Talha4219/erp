  rfqDate    DateTime             @db.Date
  dueDate    DateTime             @db.Date
  status     RfqStatus            @default(DRAFT)
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  deletedAt  DateTime?
  vendor     Vendor               @relation(fields: [vendorId], references: [id])
